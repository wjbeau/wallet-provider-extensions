{
	"name": "@algorandfoundation/log-store",
	"version": "0.0.1",
	"description": "Generalized log for extensions",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js"
		},
		"./errors": {
			"types": "./dist/errors/index.d.ts",
			"import": "./dist/errors/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist coverage node_modules",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"docs": "typedoc",
		"test": "vitest run",
		"test:cov": "vitest run --coverage",
		"bench": "vitest bench",
		"release": "package-releaser"
	},
	"author": "Algorand Foundation",
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"files": [
		"*.js",
		"*.js.map",
		"*.d.ts",
		"*.d.ts.map",
		"src/*.ts",
		"!src/*.bench.ts",
		"!src/*.test.ts"
	],
	"dependencies": {
		"@algorandfoundation/wallet-provider": "^1.0.0-canary.2",
		"before-after-hook": "^4.0.0",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@algorandfoundation/package-releaser": "0.0.1"
	},
	"peerDependencies": {
		"@tanstack/store": "^0.8.0"
	},
	"repository": {
		"type": "git",
		"directory": "logs",
		"url": "https://github.com/algorandfoundation/wallet-provider-extensions.git"
	}
}
