{
  "name": "@algorandfoundation/log-store",
  "version": "1.0.0-canary.3",
  "description": "Generalized log for extensions",
  "license": "Apache-2.0",
  "author": "Algorand Foundation",
  "repository": {
    "type": "git",
    "url": "https://github.com/algorandfoundation/wallet-provider-extensions.git",
    "directory": "log"
  },
  "type": "module",
  "sideEffects": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist coverage node_modules docs",
    "docs": "typedoc",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "bench": "vitest bench",
    "release": "package-releaser",
    "release:dry-run": "package-releaser --dry-run"
  },
  "dependencies": {
    "@algorandfoundation/wallet-provider": "catalog:"
  },
  "devDependencies": {
    "@algorandfoundation/package-releaser": "workspace:^",
    "@tanstack/store": "catalog:",
    "before-after-hook": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/store": "catalog:",
    "before-after-hook": "catalog:"
  }
}
