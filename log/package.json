{
	"name": "@algorandfoundation/log-store",
	"version": "1.0.0-canary.2",
	"description": "Generalized log for extensions",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": true,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"build:watch": "tsc -p tsconfig.build.json --watch",
		"clean": "rm -rf dist coverage node_modules docs",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"docs": "typedoc",
		"test": "vitest run",
		"test:cov": "vitest run --coverage",
		"bench": "vitest bench",
		"release": "package-releaser --dry-run"
	},
	"author": "Algorand Foundation",
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public",
		"provenance": false
	},
	"dependencies": {
		"@algorandfoundation/wallet-provider": "^1.0.0-canary.3"
	},
	"devDependencies": {
		"@algorandfoundation/package-releaser": "0.0.1",
		"@tanstack/store": "^0.8.0",
		"before-after-hook": "^4.0.0"
	},
	"peerDependencies": {
		"@tanstack/store": "^0.8.0",
		"before-after-hook": "^4.0.0"
	},
	"repository": {
		"type": "git",
		"directory": "log",
		"url": "https://github.com/algorandfoundation/wallet-provider-extensions.git"
	}
}
