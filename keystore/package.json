{
	"name": "@algorandfoundation/keystore",
	"version": "1.0.0-canary.2",
	"description": "Basic Keystore.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./extension": {
			"types": "./dist/keystore.d.ts",
			"import": "./dist/keystore.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js"
		},
		"./testing": {
			"types": "./dist/testing/index.d.ts",
			"import": "./dist/testing/index.js"
		},
		"./backend": {
			"types": "./dist/backend/index.d.ts",
			"import": "./dist/backend/index.js"
		},
		"./ipc": {
			"types": "./dist/ipc/index.d.ts",
			"import": "./dist/ipc/index.js"
		},
		"./storage": {
			"types": "./dist/storage/index.d.ts",
			"import": "./dist/storage/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"docs": "typedoc",
		"test": "vitest",
		"release": "package-releaser"
	},
	"author": "Algorand Foundation",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/algorandfoundation/wallet-provider-extensions.git",
		"directory": "keystore"
	},
	"dependencies": {
		"@algorandfoundation/dp256": "^1.1.0",
		"@algorandfoundation/wallet-provider": "^1.0.0-canary.1",
		"@algorandfoundation/xhd-wallet-api": "^2.0.0-canary.1",
		"@tanstack/store": "^0.8.0",
		"before-after-hook": "^4.0.0"
	},
	"devDependencies": {
		"vitest": "^1.0.0",
		"@algorandfoundation/package-releaser": "0.0.1"
	}
}
