{
	"name": "@algorandfoundation/keystore",
	"version": "1.0.0-canary.1",
	"description": "Basic Keystore.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": true,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js"
		},
		"./errors": {
			"types": "./dist/errors/index.d.ts",
			"import": "./dist/errors/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"docs": "typedoc",
		"test": "vitest",
		"release": "package-releaser"
	},
	"author": "Algorand Foundation",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/algorandfoundation/wallet-provider-extensions.git",
		"directory": "keystore/store"
	},
	"dependencies": {
		"@algorandfoundation/wallet-provider": "^1.0.0-canary.1",
		"@noble/hashes": "^2.0.1",
		"@scure/base": "^2.0.0",
		"@tanstack/store": "^0.8.0",
		"before-after-hook": "^4.0.0"
	},
	"devDependencies": {
		"@algorandfoundation/package-releaser": "0.0.1",
		"vitest": "^1.0.0"
	}
}
