{
	"name": "@algorandfoundation/accounts-keystore-extension",
	"version": "0.0.1",
	"description": "Accounts Keystore bridge for wallet extensions.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist coverage node_modules",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"docs": "typedoc",
		"test": "vitest run",
		"test:cov": "vitest run --coverage",
		"bench": "vitest bench"
	},
	"author": "Algorand Foundation",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/algorandfoundation/wallet-provider-extensions.git",
		"directory": "accounts/keystore-extension"
	},
	"dependencies": {
		"@algorandfoundation/wallet-provider": "^1.0.0-canary.3",
		"@algorandfoundation/accounts-store": "0.0.1",
		"@algorandfoundation/keystore": "1.0.0-canary.1"
	},
	"peerDependencies": {
		"@tanstack/store": "^0.8.0",
		"before-after-hook": "^4.0.0"
	},
	"devDependencies": {
		"@algorandfoundation/package-releaser": "0.0.1",
		"vitest": "^1.0.0"
	}
}
