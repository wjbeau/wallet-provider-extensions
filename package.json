{
  "name": "wallet-provider-extensions",
  "version": "0.0.0",
  "description": "Collection of extensions for the Wallet Provider.",
  "scripts": {
    "build": "pnpm run build:first && pnpm run build:accounts",
    "build:first": "pnpm run --filter @algorandfoundation/log-store build && pnpm run --filter @algorandfoundation/keystore build && pnpm run --filter @algorandfoundation/react-native-keystore build",
    "build:accounts": "pnpm run --filter @algorandfoundation/accounts-store build",
    "clean": "pnpm run -r --if-present clean && rm -rf coverage node_modules docs",
    "lint": "pnpm run -r --if-present lint",
    "lint:fix": "pnpm run -r --if-present lint:fix",
    "docs": "typedoc",
    "test": "pnpm run -r --if-present test",
    "release": "pnpm run -r --if-present release",
    "release:dry-run": "pnpm run -r --if-present release:dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algorandfoundation/wallet-provider-extensions.git"
  },
  "author": "Algorand Foundation",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/algorandfoundation/wallet-provider-extensions/issues"
  },
  "homepage": "https://github.com/algorandfoundation/wallet-provider-extensions#readme",
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.2.2",
    "@vitest/coverage-v8": "catalog:",
    "semantic-release": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "@babel/parser": "$@babel/parser"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ]
        }
      ],
      [
        "@semantic-release/github",
        {
          "successComment": false
        }
      ]
    ],
    "branches": [
      "release",
      {
        "name": "main",
        "prerelease": "canary"
      }
    ]
  },
  "dependencies": {
    "@babel/parser": "^7.28.6"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
