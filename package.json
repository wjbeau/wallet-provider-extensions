{
  "name": "wallet-provider-extensions",
  "version": "0.0.0",
  "description": "Collection of extensions for the Wallet Provider.",
  "workspaces": [
    "build/**",
    "log/**",
    "accounts/**",
    "keystore/**",
    "!keystore/react-native/lib/**",
    "examples/**"
  ],
  "scripts": {
    "build": "npm run build:first && npm run build:accounts",
    "build:first": "npm run build -w log --if-present && npm run build -w keystore/store --if-present",
    "build:accounts": "npm run build -w accounts/store --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf coverage node_modules docs",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "docs": "typedoc",
    "test": "npm run test --workspaces --if-present",
    "release": "npm run release --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algorandfoundation/wallet-provider-extensions.git"
  },
  "author": "Algorand Foundation",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/algorandfoundation/wallet-provider-extensions/issues"
  },
  "homepage": "https://github.com/algorandfoundation/wallet-provider-extensions#readme",
  "devDependencies": {
    "@babel/parser": "7.28.6",
    "@biomejs/biome": "2.3.14",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.2.2",
    "@vitest/coverage-v8": "^4.0.18",
    "cosmiconfig": "^9.0.0",
    "memize": "^2.1.1",
    "read-pkg": "^10.1.0",
    "semantic-release": "^25.0.3",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@babel/parser": "$@babel/parser"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ]
        }
      ],
      [
        "@semantic-release/github",
        {
          "successComment": false
        }
      ]
    ],
    "branches": [
      "release",
      {
        "name": "main",
        "prerelease": "canary"
      }
    ]
  },
  "dependencies": {
    "@babel/parser": "^7.28.6"
  }
}
