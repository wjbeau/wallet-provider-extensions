{
  "name": "@wjbeau/identities-extension",
  "version": "1.0.0-canary.1",
  "description": "Unified Identities extension for Wallet Provider.",
  "license": "Apache-2.0",
  "author": "Algorand Foundation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algorandfoundation/wallet-provider-extensions.git",
    "directory": "identities/extension"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage node_modules docs",
    "docs": "typedoc",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "release": "package-releaser",
    "release:dry-run": "package-releaser --dry-run"
  },
  "dependencies": {
    "@wjbeau/identities-keystore-extension": "workspace:*",
    "@wjbeau/identities-store": "workspace:*",
    "@wjbeau/keystore": "workspace:*",
    "@algorandfoundation/wallet-provider": "catalog:"
  },
  "devDependencies": {
    "@algorandfoundation/package-releaser": "workspace:*",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/store": "catalog:",
    "before-after-hook": "catalog:"
  }
}
